---
import Navbar from '../components/Navbar.astro';
import SEOHead from '../components/SEOHead.astro';
import Footer from '../components/Footer.astro';

const { 
  title, 
  description = "brian.conway.im: The personal hub of Brian Conway. Active projects, hosted sites, and blog posts.",
  image,
  showNavbar = true,
  noindex = false,
  boxed = true,
  showFooter = true
} = Astro.props;
---
<html lang="en">
  <head>
    <SEOHead title={title} description={description} image={image} />

    <style is:global>
      /* THEME: Tech Seaweed & Sunburst Gold */
      :root {
        --page-bg: #12332a;
        --bg-color: #0f2422;      /* Deep Seaweed Background */
        --card-bg: #173633;       /* Elevated Seaweed Card */
        --border: #25524e;        
        --text-main: #f0fdfa;    
        --text-muted: #99c2bd;    
        --accent: #eab308;        
      }

      /* Global Reset & Body */
      body { 
        font-family: system-ui, -apple-system, sans-serif;
        margin: 0; 
        background: var(--bg-color); /* Default background */
        color: var(--text-main); 
      }
      
      body.is-boxed {
        background: var(--page-bg); /* Use the darker background outside the box */
      }

      a { color: inherit; text-decoration: none; }
      h1, h2, h3 { font-weight: 700; letter-spacing: -0.01em; }

      /* The Bounding Box */
      .site-wrapper {
        max-width: 1364px;       /* Expanded for larger 150px flanks on each side */
        margin: 2rem auto;       /* Floats it off the top/bottom/sides */
        background: var(--bg-color); 
        border: 1px solid var(--border);
        border-radius: 24px;       
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); 
      }

      /* Your Original Main */
      main { 
        max-width: 1000px;
        margin: 0 auto; 
        padding: 2rem; 
      }

      /* Global Button Styles */
      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        border: 1px solid transparent;
      }
      .btn:hover { transform: translateY(-1px); }
      
      .btn-primary { 
        background: #fff; 
        color: #0f172a; 
      }
      .btn-primary:hover { background: #f1f5f9; }

      .btn-secondary { 
        background: rgba(255,255,255,0.05); 
        color: #fff; 
        border-color: var(--border); 
        margin-left: 0.5rem; 
      }
      .btn-secondary:hover { 
        background: rgba(255,255,255,0.1); 
        border-color: var(--accent); 
      }

      /* Mobile Snap */
      @media (max-width: 1400px) {
        .site-wrapper {
          max-width: 100%;
          margin: 0;
          border-radius: 0;
          border: none;
          box-shadow: none;
        }
      }
    </style>
  </head>
  <body class={boxed ? "is-boxed" : ""}>
    {boxed ? (
      <div class="site-wrapper">
        {showNavbar && <Navbar />}
        <main>
          <slot />
        </main>
        {showFooter && <Footer />}
      </div>
    ) : (
      <>
        {showNavbar && <Navbar />}
        <main>
          <slot />
        </main>
        {showFooter && <Footer />}
      </>
    )}
  </body>
</html>