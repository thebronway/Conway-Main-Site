---
import Navbar from '../components/Navbar.astro';
import SEOHead from '../components/SEOHead.astro';
import Footer from '../components/Footer.astro';

const { 
  title, 
  description = "brian.conway.im: The personal hub of Brian Conway. Active projects, hosted sites, and blog posts.",
  image,
  showNavbar = true // New prop, defaults to true
} = Astro.props;
---
<html lang="en">
  <head>
    <SEOHead title={title} description={description} image={image} />
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XQ7P529952"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-XQ7P529952');
    </script>

    <style is:global>
      /* THEME: Lighter Midnight Blue (Slate 900 Base) */
      :root {
        --bg-color: #0f172a;   
        --card-bg: #1e293b;      
        --border: #334155;       
        --text-main: #f8fafc;    
        --text-muted: #94a3b8; 
        --accent: #38bdf8;       
      }

      body { 
        font-family: system-ui, -apple-system, sans-serif; 
        margin: 0; 
        background: var(--bg-color); 
        color: var(--text-main); 
      }
      a { color: inherit; text-decoration: none; }
       
      main { 
        max-width: 1000px; 
        margin: 0 auto; 
        padding: 2rem; 
      }
       
      h1, h2, h3 { font-weight: 700; letter-spacing: -0.01em; }
       
      /* Global Button Styles */
      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        border: 1px solid transparent;
      }
      .btn:hover { transform: translateY(-1px); }
       
      .btn-primary { 
        background: #fff; 
        color: #0f172a; 
      }
      .btn-primary:hover { background: #f1f5f9; }

      .btn-secondary { 
        background: rgba(255,255,255,0.05); 
        color: #fff; 
        border-color: var(--border); 
        margin-left: 0.5rem; 
      }
      .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: #475569; }
    </style>
  </head>
  <body>
    {showNavbar && <Navbar />}
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>