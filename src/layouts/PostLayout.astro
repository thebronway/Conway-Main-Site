---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---
<BaseLayout title={frontmatter.title}>
  <article class="blog-post">
    <header>
      <h1>{frontmatter.title}</h1>
      <div class="meta">
        <time>{new Date(frontmatter.pubDate).toLocaleDateString()}</time>
        <span>•</span>
        <span>{frontmatter.author}</span>
      </div>
    </header>
    
    <div class="content">
      <slot /> 
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post { max-width: 65ch; margin: 0 auto; }
  header { margin-bottom: 3rem; text-align: center; border-bottom: 1px solid #333; padding-bottom: 2rem; }
  h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .meta { color: #888; font-size: 0.9rem; display: flex; gap: 0.5rem; justify-content: center; }
  .content { line-height: 1.8; font-size: 1.1rem; color: #d4d4d4; }
  /* Basic markdown styling */
  .content :global(h2) { margin-top: 2rem; color: #fff; }
  .content :global(a) { color: #10B981; text-decoration: underline; }
  .content :global(code) { background: #222; padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
  .content :global(pre) { background: #111 !important; padding: 1rem; border-radius: 8px; overflow-x: auto; }
</style>