---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardProject from '../../components/CardProject.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const sortOrder = { 
  'Production': 1, 
  'Live': 2,
  'Active Development': 3, 
  'Prototype': 4,
  'Planning': 5, 
  'Concept Phase': 6, 
  'Paused': 7,
  'Archived': 8, 
  'Cancelled': 9
};

const sortedProjects = projects.sort((a, b) => {
  const statusA = sortOrder[a.data.status] || 99;
  const statusB = sortOrder[b.data.status] || 99;
  if (statusA !== statusB) return statusA - statusB;
  return (a.data.order || 0) - (b.data.order || 0);
});
---

<BaseLayout title="All Projects">
  <Breadcrumbs title="Projects" />
  <h1>All Projects</h1>
  <div class="grid">
    {sortedProjects.map(p => <CardProject project={p} />)}
  </div>
</BaseLayout>

<style>
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
</style>