---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardProject from '../../components/CardProject.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

async function resolveVersion(gitUrl: string | undefined, versionField: string | undefined) {
  if (!versionField) return null;
  if (versionField !== 'fetch') return versionField;
  if (!gitUrl) return null;

  const match = gitUrl.match(/github\.com\/([^/]+)\/([^/]+)/);
  if (!match) return null;
  const [, owner, repo] = match;

  try {
    const rawUrl = `https://raw.githubusercontent.com/${owner}/${repo}/main/README.md`;
    const response = await fetch(rawUrl);
    if (!response.ok) return null;
    const text = await response.text();
    const versionMatch = text.match(/badge\/version-([v\d\.]+)-/i);
    return versionMatch ? versionMatch[1] : null;
  } catch (error) {
    console.error(`Error fetching version for ${repo}:`, error);
    return null;
  }
}

const rawProjects = await getCollection('projects');
const projects = await Promise.all(rawProjects.map(async (p) => ({
  ...p,
  data: { ...p.data, version: (await resolveVersion(p.data.gitUrl, p.data.version)) || undefined }
})));

const sortOrder = { 
  'Production': 1, 
  'Live': 2,
  'Active Development': 3, 
  'Prototype': 4,
  'Planning': 5, 
  'Concept Phase': 6, 
  'Paused': 7,
  'Archived': 8, 
  'Cancelled': 9
};

const sortedProjects = projects.sort((a, b) => {
  const statusA = sortOrder[a.data.status] || 99;
  const statusB = sortOrder[b.data.status] || 99;
  if (statusA !== statusB) return statusA - statusB;
  return (a.data.order || 0) - (b.data.order || 0);
});
---

<BaseLayout title="All Projects">
  <Breadcrumbs title="Projects" />
  <h1>All Projects</h1>
  <div class="grid">
    {sortedProjects.map(p => <CardProject project={p} />)}
  </div>
</BaseLayout>

<style>
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
</style>