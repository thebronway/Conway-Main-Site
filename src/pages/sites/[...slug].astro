---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const sites = await getCollection('sites');
  return sites.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const visitUrl = entry.data.url;
---

<BaseLayout title={entry.data.title}>
  <Breadcrumbs type="sites" title={entry.data.title} />

  <div class="hero-container">
    {entry.data.heroImage && (
      <img 
        src={entry.data.heroImage} 
        alt={entry.data.title} 
        class="hero-image" 
      />
    )}

    <div class="hero-content">
      <div class="status-wrapper">
        <StatusBadge status={entry.data.status} />
      </div>

      <h1>{entry.data.title}</h1>

      <p class="description">{entry.data.description}</p>

      {visitUrl && (
         <a href={visitUrl} target="_blank" class="launch-btn">Visit Site ↗</a>
      )}
    </div>
  </div>

  <hr style="border-color: var(--border); margin: 2rem 0;" />

  <article class="prose">
    <Content />
  </article>
</BaseLayout>

<style>
  .hero-container {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  .hero-image {
    width: 300px;
    height: auto;
    border-radius: 12px;
    border: 1px solid var(--border);
    object-fit: cover;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero-container {
      flex-direction: column;
    }
    .hero-image {
      width: 100%;
    }
  }
  
  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .status-wrapper {
    display: flex;
    margin-bottom: 1rem; 
  }

  h1 {
    margin: 0 0 0.25rem 0;
    line-height: 1.1; 
  }

  .description {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.5;
    margin: 0 0 1.5rem 0; 
  }

  .launch-btn { 
    align-self: flex-start; 
    display: inline-block; 
    background: #fff; 
    color: #0f172a; 
    padding: 0.6rem 1.2rem; 
    border-radius: 6px; 
    font-weight: bold; 
    text-decoration: none;
  }
  .launch-btn:hover { opacity: 0.9; }
</style>