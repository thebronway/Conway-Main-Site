---
import BaseLayout from '../layouts/BaseLayout.astro';
import CardProject from '../components/CardProject.astro';
import CardSite from '../components/CardSite.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

// Fetch projects, sites and blog posts
const projects = await getCollection('projects');
const sites = await getCollection('sites');
const posts = await getCollection('blog');

// Sort Projects & Sites by status
const sortOrder = { 
  'Production': 1, 
  'Live': 2,
  'Active Development': 3, 
  'Prototype': 4,
  'Planning': 5, 
  'Concept Phase': 6, 
  'Paused': 7,
  'Archived': 8, 
  'Cancelled': 9
};

const sortedProjects = projects.sort((a, b) => (sortOrder[a.data.status] || 99) - (sortOrder[b.data.status] || 99));
const sortedSites = sites.sort((a, b) => (sortOrder[a.data.status] || 99) - (sortOrder[b.data.status] || 99));

// Sort Blog Posts (Newest First) and limit to 5
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="brian.conway.im">
  
  <section class="about-section">
    <h1>Hi, I'm Brian.</h1>
    <h2>And these are my side quests.</h2>
    <p class="bio">
      • I have a passion for building practical tools that make my daily life a little more efficient and effective.<br/>
      • This hub showcases my technical product management skills, where I am the client, designer, builder, and tester.<br/>
      • I own the execution from 0 to 1, leveraging AI to assist in solving problems and bringing my raw ideas to life.
    </p>
     <p class="bio">Feel free to reach out.</p>
    
    <div class="links">
      <a href="/files/Conway_Resume.pdf" target="_blank" rel="noopener noreferrer" class="link-item">
        <Icon name="tabler:file-text" class="icon" />
        Résumé
      </a>
      <a href="mailto:brian@conway.im" class="link-item">
        <Icon name="tabler:mail" class="icon" />
        brian@conway.im
      </a>
      <a href="https://github.com/thebronway" target="_blank" rel="noopener noreferrer" class="link-item">
        <Icon name="simple-icons:github" class="icon" />
        GitHub
      </a>
      <a href="https://hub.docker.com/u/thebronway" target="_blank" rel="noopener noreferrer" class="link-item">
        <Icon name="simple-icons:docker" class="icon" />
        Dockerhub
      </a>
    </div>

  </section>

  <hr class="divider" />

  <section>
    <h2>Projects</h2>
    <div class="grid">
      {sortedProjects.map(p => <CardProject project={p} />)}
    </div>
  </section>

  <hr class="divider" />

  <section class="sites-section">
    <h2>Sites</h2>
    <div class="grid">
      {sortedSites.map(s => <CardSite site={s} />)}
    </div>
  </section>

  <hr class="divider" />

  <section class="blog-section">
    <div class="blog-header">
      <h2>Recent Blog Posts</h2>
      <a href="/blog/" class="view-all">View All →</a>
    </div>
    
    <ul class="post-list">
      {recentPosts.map(post => (
        <li>
          <a href={`/blog/${post.slug}/`} class="post-link">
            <span class="title">{post.data.title}</span>
            <span class="date">{post.data.pubDate.toLocaleDateString()}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  .about-section { margin-bottom: 3rem; margin-top: 1rem; }
  h1 { font-size: 3rem; margin-bottom: 1.5rem; color: #fff; line-height: 1; }
  .bio { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6; max-width: none; }
  
  .links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  
  .link-item { 
    display: flex;       /* Use flex to align icon and text */
    align-items: center; /* Vertically center them */
    gap: 0.5rem;         /* Space between icon and text */
    color: #fff; 
    font-weight: 600; 
    border-bottom: 1px solid transparent; 
    font-size: 1.1rem; 
    text-decoration: none; /* Remove default underline */
  }
  
  .link-item:hover { border-bottom-color: var(--accent); }

  .icon {
    width: 1.3rem; 
    height: 1.3rem;
    color: var(--text-muted); /* Start with muted color */
    transition: color 0.2s ease;
  }

  .link-item:hover .icon {
    color: #fff;
  }

  .divider { margin: 4rem 0; border: 0; border-top: 1px solid var(--border); }
  
  h2 { margin-bottom: 1.5rem; color: #fff; font-size: 1.8rem; }
  
  .grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
    gap: 1.5rem; 
  }

  .blog-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; }
  .view-all { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
  .view-all:hover { color: var(--accent); }

  .post-list { list-style: none; padding: 0; }
  .post-list li { margin-bottom: 0.75rem; }
  
  .post-link { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 1rem; 
    background: var(--card-bg); 
    border-radius: 8px; 
    border: 1px solid var(--border);
    transition: transform 0.2s, border-color 0.2s;
    text-decoration: none;
  }
  .post-link:hover { transform: translateY(-2px); border-color: #475569; }
  
  .title { font-weight: 600; color: #fff; font-size: 1.05rem; }
  .date { color: var(--text-muted); font-size: 0.85rem; font-family: monospace; }
</style>