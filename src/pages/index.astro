---
import BaseLayout from '../layouts/BaseLayout.astro';
import CardProject from '../components/CardProject.astro';
import CardSite from '../components/CardSite.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

// Fetch projects and sites
const projects = await getCollection('projects');
const sites = await getCollection('sites');

// Sort Projects & Sites by status
const sortOrder = {
  'Production': 1, 
  'Live': 2,
  'Active Development': 3, 
  'Prototype': 4,
  'Planning': 5, 
  'Concept Phase': 6, 
  'Paused': 7,
  'Archived': 8, 
  'Cancelled': 9
};

const sortedProjects = projects.sort((a, b) => {
  const statusA = sortOrder[a.data.status] || 99;
  const statusB = sortOrder[b.data.status] || 99;
  if (statusA !== statusB) return statusA - statusB;
  return (a.data.order || 0) - (b.data.order || 0);
});

const sortedSites = sites.sort((a, b) => {
  const statusA = sortOrder[a.data.status] || 99;
  const statusB = sortOrder[b.data.status] || 99;
  if (statusA !== statusB) return statusA - statusB;
  return (a.data.order || 0) - (b.data.order || 0);
});
---

<BaseLayout title="brian.conway.im">
  
  <section class="about-section">
    <h1>Hi, I'm Brian.</h1>
    <h2>And these are my side quests.</h2>
    <p class="bio">
      • I have a passion for building practical tools that make my daily life a little more efficient and effective.<br/>
      • This hub showcases my technical product management skills, where I am the client, designer, builder, and tester.<br/>
      • I own the execution from 0 to 1, leveraging AI to assist in solving problems and bringing my raw ideas to life.
    </p>
     <p class="bio">Feel free to reach out.</p>
    
    <div class="links">
      <a href="/files/Conway_Resume.pdf" target="_blank" rel="noopener noreferrer" class="link-item hover-resume">
        <Icon name="tabler:file-text" class="icon" />
        Résumé
      </a>
      <a href="mailto:brian@conway.im" class="link-item hover-email">
        <Icon name="tabler:mail" class="icon" />
        brian@conway.im
      </a>
      <a href="https://github.com/thebronway" target="_blank" rel="noopener noreferrer" class="link-item hover-github">
        <Icon name="simple-icons:github" class="icon" />
        GitHub
      </a>
      <a href="https://hub.docker.com/u/thebronway" target="_blank" rel="noopener noreferrer" class="link-item hover-docker">
        <Icon name="simple-icons:docker" class="icon" />
        Dockerhub
      </a>
      <a href="https://buymeacoffee.com/brianconway" target="_blank" rel="noopener noreferrer" class="link-item hover-bmac">
        <Icon name="simple-icons:buymeacoffee" class="icon" />
        Support my work
      </a>
    </div>

  </section>

  <hr class="divider" />

  <section>
    <h2>Projects</h2>
    <div class="grid">
      {sortedProjects.map(p => <CardProject project={p} />)}
    </div>
  </section>

  <hr class="divider" />

  <section class="sites-section">
    <h2>Sites</h2>
    <div class="grid">
      {sortedSites.map(s => <CardSite site={s} />)}
    </div>
  </section>

</BaseLayout>

<style>
  .about-section { margin-bottom: 3rem; margin-top: 1rem; }
  h1 { font-size: 3rem; margin-bottom: 1.5rem; color: #fff; line-height: 1; }
  .bio { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6; max-width: none; }
  
  .links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  
  .link-item { 
    display: flex;       /* Use flex to align icon and text */
    align-items: center; /* Vertically center them */
    gap: 0.5rem;         /* Space between icon and text */
    color: #fff; 
    font-weight: 600; 
    border-bottom: 1px solid transparent; 
    font-size: 1.1rem; 
    text-decoration: none; /* Remove default underline */
  }
  
  .link-item:hover { border-bottom-color: var(--accent); }

  .icon {
    width: 1.3rem; 
    height: 1.3rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  /* Specific Hover Colors for each icon */
  .hover-resume:hover .icon { color: #10B981; } /* Emerald Green */
  .hover-email:hover .icon { color: #38bdf8; }  /* Theme Accent Blue */
  .hover-github:hover .icon { color: #a855f7; } /* Purple */
  .hover-docker:hover .icon { color: #2496ED; } /* Official Docker Blue */
  .hover-bmac:hover .icon { color: #FFDD00; }   /* Official BMC Yellow */

  .divider { margin: 4rem 0; border: 0; border-top: 1px solid var(--border); }
  
  h2 { margin-bottom: 1.5rem; color: #fff; font-size: 1.8rem; }
  
  .grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
    gap: 1.5rem; 
  }
  
</style>