---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const title = "TheBronway | Socials";
const description = "Connect with Brian Conway on social media.";
const profileImage = "/images/card/social-headshot.webp";
const bannerImage = "/images/card/social-banner.webp";
const cardImage = "/images/card/socialcard-preview.jpg";

// Define links with their official Brand Colors
const links = [
  {
    text: "Flight Videos",
    url: "/flights",
    icon: "tabler:plane-tilt",
    color: "#0EA5E9" // Sky Blue
  },
  {
    text: "Portfolio Website",
    url: "/",
    icon: "tabler:home",
    username: "brian.conway.im",
    color: "#8B5CF6" // Emerald Green
  },
  {
    text: "Instagram",
    url: "https://instagram.com/thebronway",
    icon: "simple-icons:instagram",
    username: "@thebronway",
    color: "#E1306C" // Insta Pink
  },
  {
    text: "Twitter / X",
    url: "https://x.com/thebronway",
    icon: "simple-icons:x",
    username: "@thebronway",
    color: "#000000" // X Black
  },
  {
    text: "Facebook",
    url: "https://facebook.com/thebronway",
    icon: "simple-icons:facebook",
    username: "Brian Conway",
    color: "#1877F2" // FB Blue
  },
  {
    text: "Snapchat",
    url: "https://snapchat.com/add/thebronway",
    icon: "simple-icons:snapchat",
    username: "@thebronway",
    color: "#FFFC00" // Snap Yellow
  },
  {
    text: "Threads",
    url: "https://threads.net/@thebronway",
    icon: "simple-icons:threads",
    username: "@thebronway",
    color: "#000000" // Threads Black
  },
  {
    text: "Bluesky",
    url: "https://bsky.app/profile/thebronway.bsky.social",
    icon: "simple-icons:bluesky",
    username: "@thebronway.bsky.social",
    color: "#3B82F6" // Bluesky Blue
  },
  {
    text: "Discord",
    url: "https://discord.com/users/thebronway",
    icon: "simple-icons:discord",
    username: "@thebronway",
    color: "#5865F2" // Discord Blurple
  },
  {
    text: "GitHub",
    url: "https://github.com/thebronway",
    icon: "simple-icons:github",
    username: "@thebronway",
    color: "#6e5494" // GitHub Purple (Official secondary brand color)
  },
  {
    text: "DockerHub",
    url: "https://hub.docker.com/u/thebronway",
    icon: "simple-icons:docker",
    username: "@thebronway",
    color: "#2496ED" // Docker Blue
  },
];
---

<BaseLayout title={title} description={description} showNavbar={false}>
  <div class="vibrant-bg"></div>

  <section class="card-container">
    <div class="banner-wrapper">
      <img src={bannerImage} alt="" class="banner-image" />
    </div>

    <div class="header">
      <div class="image-wrapper">
        <img src={profileImage} alt="Brian Conway" class="profile-image" />
      </div>
      <h1>TheBronway</h1>
      <p class="subtitle">( The Brian Conway )</p>
    </div>

    <div class="link-list">
      {links.map((link, index) => (
        <a 
          href={link.url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="link-card"
          style={`--brand-color: ${link.color}; animation-delay: ${index * 100}ms`}
        >
          <div class="icon-box">
            <Icon name={link.icon} class="icon" />
          </div>
          <div class="link-info">
            <span class="link-text">{link.text}</span>
            <span class="link-subtext">{link.username}</span>
          </div>
          <Icon name="tabler:external-link" class="arrow" />
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* 1. Vibrant Background */
  .vibrant-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
      radial-gradient(at 0% 0%, rgba(225, 48, 108, 0.3) 0px, transparent 50%),
      radial-gradient(at 100% 0%, rgba(88, 101, 242, 0.3) 0px, transparent 50%),
      radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.3) 0px, transparent 50%),
      radial-gradient(at 0% 100%, rgba(255, 252, 0, 0.2) 0px, transparent 50%);
    background-color: #0f172a;
    z-index: -1;
    pointer-events: none;
  }

  .card-container {
    max-width: 500px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  /* 2. UPDATED BANNER STYLES */
  .banner-wrapper {
    width: 100%;
    /* Remove fixed height (150px) */
    /* Force the aspect ratio to match your photo (1040 / 768) */
    aspect-ratio: 1040 / 768; 
    overflow: hidden;
    border-radius: 0 0 24px 24px;
    
    /* Keep the negative margin so the headshot still overlaps the bottom edge */
    margin-bottom: -75px; 
    
    position: relative;
    z-index: 1;
  }

  .banner-image {
    width: 100%;
    height: 100%;
    /* Change from 'cover' to 'contain' (or just fill 100%) so we see the whole image */
    object-fit: contain; 
    background-color: var(--card-bg); /* Fallback color if aspect ratio varies slightly */
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
    z-index: 2;
    animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .image-wrapper {
    display: inline-block;
    padding: 4px;
    background: var(--card-bg);
    border-radius: 50%;
    margin-bottom: 1rem;
  }

  .profile-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--card-bg);
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    color: #fff;
    font-weight: 800;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  .subtitle {
    color: var(--accent); /* Pop of color */
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0 1rem;
  }

  .link-card {
    position: relative;
    display: flex;
    align-items: center;
    padding: 1rem 1.25rem;
    background: rgba(30, 41, 59, 0.7);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0; 
    animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .link-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: var(--brand-color);
    box-shadow: 0 0 25px -5px var(--brand-color);
    background: rgba(30, 41, 59, 0.9);
  }

  .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    margin-right: 1rem;
    color: var(--brand-color);
    transition: all 0.3s ease;
  }

  .link-card:hover .icon-box {
    background: var(--brand-color);
    color: #0f172a;
  }

  .link-card:hover[style*="#000000"] .icon-box { 
     color: #ffffff !important; 
  }

  .link-card[style*="#000000"] .icon-box {
    color: #ffffff;
  }

  .icon {
    width: 1.6rem;
    height: 1.6rem;
  }

  .link-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .link-text {
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .link-subtext {
    color: var(--text-muted);
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .arrow {
    color: var(--text-muted);
    width: 1.2rem;
    height: 1.2rem;
    transition: all 0.2s;
  }

  .link-card:hover .arrow {
    color: var(--brand-color);
    transform: translateX(3px) rotate(-45deg);
  }
</style>