---
const today = new Date();
---

<footer>
  <div class="content">
    <p>
      &copy; {today.getFullYear()} Brian Conway. All rights reserved.
    </p>
    <p class="support">
      Find my projects helpful? <a href="https://buymeacoffee.com/brianconway" target="_blank" rel="noopener noreferrer">Buy me a coffee</a>
    </p>
  </div>
</footer>

<style>
  .support {
    margin-top: 0.5rem;
  }
  .support a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .support a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  footer {
    padding: 3rem 2rem;
    text-align: center;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    margin-top: auto; /* pushes footer to bottom */
  }

  .content {
    max-width: 1000px;
    margin: 0 auto;
  }
</style>