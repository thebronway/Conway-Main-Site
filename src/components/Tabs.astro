---
<div class="tabs-wrapper">
  <ul class="tab-list" role="tablist"></ul>
  <div class="tab-content">
    <slot />
  </div>
</div>

<style>
  .tabs-wrapper { margin-top: 2rem; }
  .tab-list {
    display: flex;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    overflow-y: hidden;
    
    /* Hide scrollbar for Firefox, IE, and Edge */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .tab-list::-webkit-scrollbar {
    display: none;
  }
  
  /* Global styles for the buttons generated by our script */
  :global(.tab-btn) {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 0.5rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    margin-bottom: -1px;
    white-space: nowrap;
  }
  
  :global(.tab-btn:hover) { 
    color: #fff; 
  }
  
  :global(.tab-btn.active) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>

<script>
  // This script runs on the client to wire up the tabs
  document.addEventListener('DOMContentLoaded', () => {
    const tabWrappers = document.querySelectorAll('.tabs-wrapper');
    
    tabWrappers.forEach(wrapper => {
      const tabList = wrapper.querySelector('.tab-list');
      const panels = wrapper.querySelectorAll('.tab-panel');
      
      panels.forEach((panel, index) => {
        const label = panel.getAttribute('data-label');
        
        // Create the button
        const btn = document.createElement('button');
        btn.className = `tab-btn ${index === 0 ? 'active' : ''}`;
        btn.textContent = label;
        btn.setAttribute('role', 'tab');
        
        const li = document.createElement('li');
        li.appendChild(btn);
        tabList.appendChild(li);
        
        // Hide all panels except the first one initially
        if (index !== 0) (panel as HTMLElement).style.display = 'none';
        
        // Add click listener
        btn.addEventListener('click', () => {
          // Deactivate all buttons and hide all panels
          wrapper.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          panels.forEach(p => (p as HTMLElement).style.display = 'none');
          
          // Activate clicked button and show its panel
          btn.classList.add('active');
          (panel as HTMLElement).style.display = 'block';
        });
      });
    });
  });
</script>